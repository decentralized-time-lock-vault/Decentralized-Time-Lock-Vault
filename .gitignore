# Rust build artifacts
/target
**/*.rs.bk

# Soroban compiled WASM output
contracts/*/target

# Environment secrets
.env
.env.local
.env.*.local

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Soroban CLI config (may contain private keys)
.soroban/

# Soroban test-environment XDR snapshots generated by `cargo test`.
# These are build artefacts, not regression fixtures — ignore them.
contracts/*/test_snapshots/
**/.soroban/
*.snap
*.snapshot

# Optimized WASM output
contracts/*/optimized/
*.wasm

# Cargo lock for libraries (keep for binaries/contracts)
# Cargo.lock is intentionally committed for reproducible builds

# Coverage reports
lcov.info
tarpaulin-report.html
coverage/

# Profiling data
*.profraw
*.profdata
