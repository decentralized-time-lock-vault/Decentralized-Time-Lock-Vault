# Rust build artifacts
/target
**/*.rs.bk

# Soroban compiled WASM output
contracts/*/target

# Environment secrets
.env
.env.local
.env.*.local

# Editor directories
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Soroban CLI config (may contain private keys)
.soroban/

# Soroban test-environment XDR snapshots generated by `cargo test`.
# These are build artefacts, not regression fixtures — ignore them.
contracts/*/test_snapshots/

# Optimized WASM output
*.optimized.wasm
contracts/*/optimized/

# Temporary / misc
*.log
*.tmp

# Cargo lock for libraries (keep for binaries/contracts)
# Uncomment if this is a library crate:
# Cargo.lock

# Coverage reports
lcov.info
tarpaulin-report.html
coverage/

# Profiling / flamegraph artifacts
perf.data
perf.data.old
flamegraph.svg

# Soroban test snapshots (all patterns)
**/.soroban/
**/test_snapshots/
*.snap
